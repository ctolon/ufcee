{
  "outputStyle": "ucee-house",
  "env": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    "RUSTFLAGS": "-D warnings",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(rustc *)",
      "Bash(rustdoc *)",
      "Bash(rustfmt *)",
      "Bash(maturin *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pyright *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git fetch *)",
      "Bash(git worktree *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git show *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(fd *)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:doc.rust-lang.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:tokio.rs)",
      "WebFetch(domain:pyo3.rs)",
      "WebFetch(domain:helm.sh)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git rebase *)",
      "Bash(cargo install *)",
      "Bash(cargo publish *)",
      "Bash(maturin publish *)",
      "Bash(uv publish *)",
      "Bash(helm *)",
      "Bash(kubectl *)",
      "Write(./.github/workflows/**)",
      "Write(./Cargo.toml)",
      "Write(./pyproject.toml)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(git push --force main*)",
      "Bash(git push --force-with-lease main*)",
      "Bash(git push origin --force main*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/scripts/no_ai_slop.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/scripts/guard_bash.sh", "timeout": 5 },
          { "type": "command", "command": ".claude/hooks/scripts/guard_commit_message.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/scripts/post_lint_rust.sh", "timeout": 60 },
          { "type": "command", "command": ".claude/hooks/scripts/post_lint_python.sh", "timeout": 30 },
          { "type": "command", "command": ".claude/hooks/scripts/post_slop_scan.sh", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": ".claude/hooks/scripts/inject_coordination.sh", "timeout": 3 } ] }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": ".claude/hooks/scripts/session_start.sh", "timeout": 5 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": ".claude/hooks/scripts/session_summary.sh", "timeout": 10 } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": ".claude/hooks/scripts/dump_state.sh", "timeout": 10 } ] }
    ]
  }
}
